    {
      "slot": "passive",
      "name": "Flow of the World",
      "description": "Can change Flow states at the Base to enhance stats.\nVitality: Increases max Health and Physical and Magical Defense.\nPiercing Heart: Increases max Health and Physical Attack.\nHaste: Increases max Health and Movement Speed.\nFocus: Increases max Health and Cooldown Reduction.\nSpend 1 stack of Flow to perform an enhanced Basic Attack and deal damage and gain recovery.",
      "icon": "https://game.gtimg.cn/images/yxzj/img201606/heroimg/581/58107.png",
      "cooldown": null
    },
    {
      "slot": "skill1",
      "name": "Convergence",
      "description": "Channels the Flow, reducing the cooldown of other skills by 50%. Also gains 5–9 stacks of Flow based on the number of nearby heroes and minions and recovers Health based on Flow stacks.\nDamages and knocks back nearby enemies (without applying crowd control).",
      "icon": "https://game.gtimg.cn/images/yxzj/img201606/heroimg/581/58170.png",
      "cooldown": null
    },
    {
      "slot": "skill2",
      "name": "Power From Within",
      "description": "Charges at the target and slashes, dealing damage, launching enemies, and gaining a shield.\nUsing the skill continuously over a short time converts it to Clearing Slash and Rifting Slash.\nIf the skill is not on cooldown, spend 4 stacks of Flow to stop it from entering cooldown after use.",
      "icon": "https://game.gtimg.cn/images/yxzj/img201606/heroimg/581/58180.png",
      "cooldown": null
    },
    {
      "slot": "ultimate",
      "name": "All In",
      "description": "Leaps to the target location and attacks, dealing damage and launching enemies.\nIf the skill is not on cooldown, spend 5 stacks of Flow to stop it from entering cooldown after this use.",
