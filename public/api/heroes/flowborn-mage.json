      "cooldown": null
    },
    {
      "slot": "skill1",
      "name": "Convergence",
      "description": "Channels the Flow, reducing the cooldown of other skills by 50%. Also gains 5–9 stacks of Flow based on the number of nearby heroes and minions and recovers Health based on Flow stacks.\nDamages and knocks back nearby enemies (without applying crowd control).",
      "icon": "https://game.gtimg.cn/images/yxzj/img201606/heroimg/582/58210.png",
      "cooldown": null
    },
    {
      "slot": "skill2",
      "name": "Flow Formation",
      "description": "Deals damage and slows enemies within range, then deals damage over time.\nUsing the skill repeatedly within a short time enhances it, dealing damage and launching or stunning enemies. When new magic circles overlap with the initial one, they increase its damage and refresh its duration.\nCan spend 4 stacks of Flow to use the skill without triggering cooldown.",
      "icon": "https://game.gtimg.cn/images/yxzj/img201606/heroimg/582/58220.png",
      "cooldown": null
    },
    {
      "slot": "ultimate",
      "name": "Arcane Arts",
      "description": "Continuously channels a beam to deal damage over time.\nWhile the beam is linked with a hero, continuously throws Energy Bombs that deal area damage.\nCan spend 5 stacks of Flow to stop the skill from entering cooldown after this use.",
      "icon": "https://game.gtimg.cn/images/yxzj/img201606/heroimg/582/58230.png",
      "cooldown": null
